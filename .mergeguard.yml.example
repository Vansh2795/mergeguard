# MergeGuard Configuration
# Place this file as .mergeguard.yml in your repository root.

# Only post a comment if the risk score exceeds this threshold (0-100)
risk_threshold: 50

# Enable regression detection against recently merged PRs
check_regressions: true

# Maximum number of open PRs to analyze (safety cap)
max_open_prs: 200

# Only scan PRs updated within this many days
max_pr_age_days: 30

# How many recently merged PRs to track for regression detection
decisions_log_depth: 50

# Enable LLM-powered semantic analysis (requires anthropic-api-key)
llm_enabled: false
llm_model: "claude-sonnet-4-20250514"

# Max transitive conflicts detected per PR pair (default: 5)
max_transitive_per_pair: 5

# Post inline review comments on conflicting lines (default: true)
inline_annotations: true

# Custom risk scoring weights (must sum to ~1.0)
# Uncomment to override defaults:
# risk_weights:
#   conflict_severity: 0.40
#   blast_radius: 0.20
#   pattern_deviation: 0.15
#   churn_risk: 0.15
#   ai_attribution: 0.10

# File patterns to ignore during analysis
ignored_paths:
  - "*.lock"
  - "*.min.js"
  - "*.min.css"
  - "package-lock.json"
  - "yarn.lock"
  - "pnpm-lock.yaml"
  - "poetry.lock"

